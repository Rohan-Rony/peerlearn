PORT=5000
DB_USER=postgres
DB_HOST=localhost
DB_NAME=peerlearn
DB_PASSWORD=1234
DB_PORT=5432
JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=7d

# Frontend origin used for Stripe success/cancel redirects
