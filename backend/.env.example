# Stripe
STRIPE_SECRET_KEY=sk_test_xxx

# Keep this true to bypass gateway and directly enroll on "Enroll Now".
SIMULATE_PAYMENTS=true

# Optional: AI-powered tutor verification quiz generation.
# If not provided, backend uses topic-aware fallback questions.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
